{
  "name": "ondo-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Ondo - Airtel/Moov payment processing",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "node-forge": "^1.4.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/node-forge": "^1.3.14",
    "typescript": "~5.4.0"
  },
  "private": true
}
